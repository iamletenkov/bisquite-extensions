[Unit]
Description=Configure LXDE/LightDM autologin from cloud-init user
DefaultDependencies=no
After=local-fs.target network-online.target
Before=lightdm.service display-manager.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash /opt/vmsetup/lxde/configure.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=configure-lxde
TimeoutStartSec=300

[Install]
WantedBy=lightdm.service display-manager.service
